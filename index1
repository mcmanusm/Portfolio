let mode = 'agencies';

const map = L.map('map').setView([-26.5, 134], 4);
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap, © CARTO', maxZoom: 19
}).addTo(map);

function fmt(n) {
  if (n >= 1000) return (n/1000).toFixed(1) + 'k';
  return Math.round(n).toString();
}
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// Sizing scales — sqrt for both so visual area is proportional to count
function agencyRadius(n) { return n === 0 ? 4 : 6 + Math.sqrt(n) * 4; }
function agencyColor(n) {
  if (n === 0) return '#B8C5D1';
  if (n <= 2) return '#5BB3E8';
  if (n <= 5) return '#1E88D2';
  return '#0F2540';
}
function buyerRadius(n) {
  if (n === 0) return 3;
  return 4 + Math.sqrt(n) * 1.6;   // tuned for 0–1400 range
}
function buyerColor(n) {
  if (n <= 5)   return '#5BB3E8';
  if (n <= 25)  return '#1E88D2';
  if (n <= 100) return '#0F2540';
  return '#C2410C';   // hottest spots in livestock-buyer rust
}

function makeClusterGroup() {
  return L.markerClusterGroup({
    showCoverageOnHover: false,
    spiderfyOnMaxZoom: true,
    zoomToBoundsOnClick: true,
    maxClusterRadius: 40,
    spiderfyDistanceMultiplier: 1.6,
    iconCreateFunction: function(cluster) {
      const count = cluster.getChildCount();
      let cls, size;
      if (count >= 50)      { cls = 'xlarge'; size = 56; }
      else if (count >= 15) { cls = 'large';  size = 48; }
      else if (count >= 5)  { cls = 'medium'; size = 40; }
      else                  { cls = 'small';  size = 32; }
      return L.divIcon({
        html: '<div class="ap-cluster ' + cls + '">' + count + '</div>',
        className: 'ap-cluster-wrapper',
        iconSize: [size, size]
      });
    }
  });
}

function agencyCard(d) {
  return (
    '<div class="card">' +
      '<div class="card-header">' +
        '<div class="card-title">' + escapeHtml(d.c) + '</div>' +
        '<div class="card-sub">' + escapeHtml(d.t) + ', ' + escapeHtml(d.s) +
          (d.r ? ' &middot; ' + escapeHtml(d.r) : '') + '</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="species-grid">' +
          '<div class="species cattle">' +
            '<div class="species-label">Cattle</div>' +
            '<div class="big-num">' + d.ca + '</div>' +
            '<div class="species-stat"><span class="k">Assessors</span></div>' +
          '</div>' +
          '<div class="species sheep">' +
            '<div class="species-label">Sheep</div>' +
            '<div class="big-num">' + d.sa + '</div>' +
            '<div class="species-stat"><span class="k">Assessors</span></div>' +
          '</div>' +
        '</div>' +
        '<div class="footer-stats">' +
          '<div><span class="k">Total assessors </span><span class="v">' + d.a + '</span></div>' +
          '<div><span class="k">Branches </span><span class="v">' + d.br + '</span></div>' +
        '</div>' +
      '</div>' +
    '</div>'
  );
}

function buyerCard(d) {
  return (
    '<div class="card">' +
      '<div class="card-header">' +
        '<div class="card-title">' + escapeHtml(d.t) + '</div>' +
        '<div class="card-sub">' + escapeHtml(d.s) + (d.pc ? ' &middot; ' + d.pc : '') + '</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="species-grid">' +
          '<div class="species livestock">' +
            '<div class="species-label">Livestock</div>' +
            '<div class="big-num">' + d.lb.toLocaleString() + '</div>' +
            '<div class="species-stat"><span class="k">Buyers</span></div>' +
          '</div>' +
          '<div class="species machinery">' +
            '<div class="species-label">Machinery</div>' +
            '<div class="big-num">' + d.mb.toLocaleString() + '</div>' +
            '<div class="species-stat"><span class="k">Buyers</span></div>' +
          '</div>' +
        '</div>' +
        '<div class="footer-stats">' +
          '<div><span class="k">Total buyers </span><span class="v">' + d.tot.toLocaleString() + '</span></div>' +
        '</div>' +
      '</div>' +
    '</div>'
  );
}

let markerLayer = makeClusterGroup().addTo(map);

function rebuildSizeBy() {
  const sel = document.getElementById('sizeBy');
  sel.innerHTML = '';
  const opts = mode === 'agencies'
    ? [['a','Total assessors'], ['ca','Cattle assessors'], ['sa','Sheep assessors']]
    : [['tot','Total buyers'],  ['lb','Livestock buyers'], ['mb','Machinery buyers']];
  opts.forEach(([v,l]) => {
    const o = document.createElement('option');
    o.value = v; o.textContent = l; sel.appendChild(o);
  });
}

function render() {
  const stateF  = document.getElementById('stateFilter').value;
  const sizeBy  = document.getElementById('sizeBy').value;
  const cluster = document.getElementById('clusterMode').value === 'on';

  if (markerLayer) map.removeLayer(markerLayer);
  markerLayer = cluster ? makeClusterGroup() : L.layerGroup();
  markerLayer.addTo(map);

  if (mode === 'agencies') {
    let shown = 0, totalAssessors = 0;
    AGENCY_DATA.forEach(d => {
      if (stateF !== 'all' && d.s !== stateF) return;
      shown++;
      totalAssessors += d.a;
      const v = d[sizeBy];
      const m = L.circleMarker([d.lat, d.lon], {
        radius: agencyRadius(v),
        fillColor: agencyColor(v),
        color: '#0F2540',
        weight: 1.5,
        opacity: 0.95,
        fillOpacity: v === 0 ? 0.45 : 0.8
      });
      m.bindPopup(agencyCard(d), { maxWidth: 320, minWidth: 280 });
      markerLayer.addLayer(m);
    });
    document.getElementById('stats').textContent =
      shown.toLocaleString() + ' branches · ' + totalAssessors.toLocaleString() + ' assessors';
  } else {
    let shown = 0, totalLB = 0, totalMB = 0;
    BUYER_DATA.forEach(d => {
      if (stateF !== 'all' && d.s !== stateF) return;
      shown++;
      totalLB += d.lb;
      totalMB += d.mb;
      const v = d[sizeBy];
      const m = L.circleMarker([d.lat, d.lon], {
        radius: buyerRadius(v),
        fillColor: buyerColor(v),
        color: '#0F2540',
        weight: 1,
        opacity: 0.85,
        fillOpacity: 0.75
      });
      m.bindPopup(buyerCard(d), { maxWidth: 320, minWidth: 280 });
      markerLayer.addLayer(m);
    });
    document.getElementById('stats').textContent =
      shown.toLocaleString() + ' towns · ' +
      totalLB.toLocaleString() + ' livestock · ' +
      totalMB.toLocaleString() + ' machinery';
  }
  rebuildLegend();
}

function switchMode(newMode) {
  mode = newMode;
  document.getElementById('modeAgencies').classList.toggle('active', mode === 'agencies');
  document.getElementById('modeBuyers').classList.toggle('active', mode === 'buyers');
  document.getElementById('title').textContent =
    mode === 'agencies' ? 'Agency Network' : 'Buyer Network';
  document.getElementById('subtitle').textContent =
    mode === 'agencies'
      ? 'Bubble size = assessors · click clusters to expand'
      : 'Bubble size = buyer count · click clusters to expand';
  rebuildSizeBy();
  render();
}

document.getElementById('modeAgencies').addEventListener('click', () => switchMode('agencies'));
document.getElementById('modeBuyers').addEventListener('click',  () => switchMode('buyers'));
['stateFilter','sizeBy','clusterMode'].forEach(id =>
  document.getElementById(id).addEventListener('change', render)
);

// Legend control — rebuilds per mode
let legendCtrl = null;
function rebuildLegend() {
  if (legendCtrl) map.removeControl(legendCtrl);
  legendCtrl = L.control({ position: 'bottomright' });
  legendCtrl.onAdd = function() {
    const div = L.DomUtil.create('div', 'legend');
    if (mode === 'agencies') {
      div.innerHTML =
        '<h4>Assessors per branch</h4>' +
        '<div class="row"><span class="dot" style="width:6px;height:6px;background:#B8C5D1;"></span>0</div>' +
        '<div class="row"><span class="dot" style="width:12px;height:12px;background:#5BB3E8;"></span>1–2</div>' +
        '<div class="row"><span class="dot" style="width:16px;height:16px;background:#1E88D2;"></span>3–5</div>' +
        '<div class="row"><span class="dot" style="width:22px;height:22px;background:#0F2540;"></span>6+</div>' +
        '<div class="muted">Click clusters to zoom · click bubbles for details</div>';
    } else {
      div.innerHTML =
        '<h4>Buyers per town</h4>' +
        '<div class="row"><span class="dot" style="width:8px;height:8px;background:#5BB3E8;"></span>1–5</div>' +
        '<div class="row"><span class="dot" style="width:12px;height:12px;background:#1E88D2;"></span>6–25</div>' +
        '<div class="row"><span class="dot" style="width:16px;height:16px;background:#0F2540;"></span>26–100</div>' +
        '<div class="row"><span class="dot" style="width:22px;height:22px;background:#C2410C;"></span>100+</div>' +
        '<div class="muted">Click clusters to zoom · click bubbles for details</div>';
    }
    return div;
  };
  legendCtrl.addTo(map);
}

rebuildSizeBy();
render();
</script>
